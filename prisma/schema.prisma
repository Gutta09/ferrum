// Ferrum — MongoDB (Atlas) via Prisma. Document store; every id maps to _id and
// user-owned documents carry userId. The ownership scoping built into the app
// maps onto these the same way it did on Postgres.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid()) @map("_id")
  email        String   @unique
  name         String
  passwordHash String?
  createdAt    DateTime @default(now())

  workouts     Workout[]
  exercises    Exercise[]
  ownedCircles Circle[]           @relation("CircleOwner")
  memberships  CircleMembership[]
}

model Exercise {
  id         String @id @default(cuid()) @map("_id")
  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  muscle     String
  equipment  String
  difficulty String

  @@index([userId])
}

model Workout {
  id          String            @id @default(cuid()) @map("_id")
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  date        String // ISO yyyy-mm-dd, local day
  durationMin Int
  createdAt   DateTime          @default(now())
  exercises   WorkoutExercise[]

  @@index([userId, date])
}

model WorkoutExercise {
  id         String     @id @default(cuid()) @map("_id")
  workoutId  String
  workout    Workout    @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exerciseId String
  position   Int
  notes      String?
  sets       SetEntry[]

  @@index([workoutId])
}

model SetEntry {
  id                String          @id @default(cuid()) @map("_id")
  workoutExerciseId String
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  position          Int
  weight            Float
  reps              Int
  rpe               Float?
  completed         Boolean         @default(true)
  isPR              Boolean         @default(false)

  @@index([workoutExerciseId])
}

// --- Circles: private, invite-only accountability pods ---

model Circle {
  id         String   @id @default(cuid()) @map("_id")
  name       String
  ownerId    String
  owner      User     @relation("CircleOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  inviteCode String   @unique
  memberCap  Int      @default(8)
  createdAt  DateTime @default(now())

  members    CircleMembership[]
  challenges Challenge[]
}

model CircleMembership {
  id       String   @id @default(cuid()) @map("_id")
  circleId String
  circle   Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     String   @default("member")
  joinedAt DateTime @default(now())

  shareConsistency Boolean @default(true)
  shareActivity    Boolean @default(true)
  shareWeights     Boolean @default(false)
  sharePRs         Boolean @default(false)

  @@unique([circleId, userId])
  @@index([userId])
}

model Challenge {
  id            String   @id @default(cuid()) @map("_id")
  circleId      String
  circle        Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  name          String
  startDate     String
  endDate       String
  targetPerWeek Int      @default(4)
  createdAt     DateTime @default(now())

  @@index([circleId])
}
